#include <iostream>
#include <string>
#include <sstream>
#include <vector>
#include <cstdint>
#include <bitset>

using namespace std;

uint32_t ipToUint(const string& ip) {
    vector<int> octets;
    stringstream ss(ip);
    string octet;

    while (getline(ss, octet, '.')) {
        octets.push_back(stoi(octet));
    }

    if (octets.size() != 4) return 0;

    return (octets[0] << 24) | (octets[1] << 16) | (octets[2] << 8) | octets[3];
}

int main() {

    string A, B, C;

    cout << "Enter IP1 IP2 mask:";
    cin >> A >> B >> C;

    uint32_t a = ipToUint(A);
    uint32_t b = ipToUint(B);
    uint32_t c = ipToUint(C);

    if (a == 0 || b == 0 || c == 0) {
        cerr << "Error" << endl;
        return 0;
    }

    uint32_t ac = a & c;
    uint32_t bc = b & c;

    cout << "A: " << bitset<32>(a) << "\nB " << bitset<32>(b) << "\nC: " << bitset<32>(c) << endl;
    cout << (ac == bc ? "True" : "False") << endl;
   
    system("PAUSE");
}

