#include <iostream>
#include <vector>
#include <cmath>

using namespace std;

int main() {
    setlocale(LC_ALL, "Russian");

    vector<double> x; // Исходный вектор
    vector<double> y; // Новый вектор для результата


    if (x.size() == 10) {
        cout << "Вектор x заполнен 10 элементами!" << endl;


        for (double value : x) {
            y.push_back(pow(value, 2) - 1);
        }

        cout << "Вектор x: ";
        for (double num : x) {
            cout << num << " ";
        }
        cout << endl;

        cout << "Вектор y (x^2 - 1): ";
        for (double num : y) {
            cout << num << " ";
        }
        cout << endl;
    }

    else if (x.empty()) {
        cout << "Вектор x пустой! Введите количество элементов: ";
        int n;
        cin >> n;

        cout << "Введите " << n << " элементов:" << endl;
        for (int i = 0; i < n; i++) {
            double value;
            cin >> value;
            x.push_back(value);
        }

        cout << "Вектор x: ";
        for (double num : x) {
            cout << num << " ";
        }
        cout << endl;


        for (double value : x) {
            y.push_back(pow(value, 2) - 1);
        }

        cout << "Вектор y (x^2 - 1): ";
        for (double num : y) {
            cout << num << " ";
        }
        cout << endl;
    }

    return 0;
}
