#include <iostream>
#include <vector>
#include <cmath>

using namespace std;

int main() {
    setlocale(LC_ALL, "Russian");

    vector<double> x; // Исходный вектор
    vector<double> y; // Новый вектор для результата

    cout << "Введите количество элементов: ";
    int n;
    cin >> n;

    cout << "Введите " << n << " элементов:" << endl;
    for (int i = 0; i < n; i++) {
        double value;
        cin >> value;
        x.push_back(value);
    }

    // Вычисляем y = x^2 - 1 для каждого элемента
    for (double value : x) {
        y.push_back(pow(value, 2) - 1);
    }

    cout << "\nВектор x: ";
    for (double num : x) {
        cout << num << " ";
    }
    cout << endl;

    cout << "Вектор y (x^2 - 1): ";
    for (double num : y) {
        cout << num << " ";
    }
    cout << endl;

    // Дополнительная проверка для случая, когда вектор заполнен 10 элементами
    if (x.size() == 10) {
        cout << "\n(Вектор x заполнен 10 элементами!)" << endl;
    }

    return 0;
}




#include <iostream>
#include <vector>
#include <iomanip>
#include <random>
using namespace std;

int main()
{
    setlocale(LC_ALL, "Russian");
    int m, n;
    double minVal, maxVal;
    cout << "Введите количество строк (m): ";
    cin >> m;
    cout << "Введите количество столбцов (n): ";
    cin >> n;
    cout << "Введите минимальное значение: ";
    cin >> minVal;
    cout << "Введите максимальное значение: ";
    cin >> maxVal;

    random_device rd;
    mt19937 gen(rd());
    uniform_real_distribution<double> dist(minVal, maxVal);

    vector<vector<double>> X(m, vector<double>(n));

    cout << "\nСгенерированная матрица X:" << endl;
    for (int i = 0; i < m; i++) {
        cout << "Строка " << i << ": ";
        for (int j = 0; j < n; j++) {
            X[i][j] = dist(gen);
            cout << fixed << setprecision(2) << X[i][j] << " ";
        }
        cout << endl;
    }

    double totalSum = 0;
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            totalSum += X[i][j];
        }
    }
    double totalAverage = totalSum / (m * n);

    cout << "\nСреднее арифметическое всех элементов: " << fixed << setprecision(4) << totalAverage << endl;

    if (totalAverage > 0) {
        cout << "Среднее положительно! Меняем местами левую и правую половины..." << endl;
        int half = n / 2;
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < half; j++) {
                int rightCol = n - 1 - j;
                if (j < rightCol) {
                    swap(X[i][j], X[i][rightCol]);
                }
            }
        }
        cout << "\nПреобразованная матрица:" << endl;
        for (int i = 0; i < m; i++) {
            cout << "Строка " << i << ": ";
            for (int j = 0; j < n; j++) {  // ← ОШИБКА: здесь была точка с запятой
                cout << fixed << setprecision(2) << X[i][j] << " ";
            }
            cout << endl;
        }
    }
    else {
        cout << "Среднее не положительно. Матрица осталась без изменений." << endl;
    }
    return 0;
}
